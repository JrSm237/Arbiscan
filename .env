PORT=3000

# ── TELEGRAM ALERTES ──────────────────────────────────────────────────────────
# Obtenir via @BotFather sur Telegram → /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID du chat/groupe où envoyer les alertes
# Perso : ton ID numérique (ex: 123456789)
# Groupe : commence par -100 (ex: -1001234567890)
TELEGRAM_CHAT_ID=-1001234567890

# Seuil de déclenchement des alertes (spread en %)
ALERT_SPREAD=2.0

# Intervalle du scanner automatique en ms (60000 = 60s)
SCAN_INTERVAL=60000

# Nombre de paires scannées automatiquement
AUTO_SCAN_PAIRS=50
