PORT=3000

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
ALERT_SPREAD=2.0
SCAN_INTERVAL=60000

# ── BOT D'EXÉCUTION ───────────────────────────────────────────────────────────
# OKX API (permissions: Read + Trade UNIQUEMENT — PAS de retrait)
OKX_API_KEY=votre-okx-api-key
OKX_SECRET=votre-okx-secret
OKX_PASSPHRASE=votre-okx-passphrase

# HTX API (permissions: Read + Trade UNIQUEMENT — PAS de retrait)
HTX_API_KEY=votre-htx-api-key
HTX_SECRET=votre-htx-secret

# Config bot
MIN_SPREAD_PCT=2.0       # Spread minimum pour déclencher un trade
CAPITAL_PER_LEG=10       # USDT à utiliser par leg (achat ou vente)
DRY_RUN=true             # true = simulation, false = vrais trades

# ── ADMIN ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=votre-cle-admin-secrete
ADMIN_EMAIL=votre@email.com
ADMIN_PASSWORD=votre-mot-de-passe-admin
# JWT_SECRET=une-chaine-aleatoire-longue-pour-signer-les-tokens

